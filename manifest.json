{
  "name": "Twitch Now MV3",
  "short_name": "Twitch Now",
  "version": "1.1.221",
  "default_locale": "en",
  "manifest_version": 3,
  "description": "Twitch Now updated for Manifest V3 and current Chrome versions.",
  "content_scripts": [
    {
      "run_at": "document_start",
      "matches": [
        "*://*.twitch.tv/*"
      ],
      "all_frames": true,
      "js": [
        "common/content/theatre-mode.js"
      ]
    }
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "minimum_chrome_version": "116",
  "icons": {
    "16": "common/icons/32_1.png",
    "48": "common/icons/48_1.png",
    "128": "common/icons/128_1.png"
  },
  "action": {
    "default_icon": {
      "19": "common/icons/19_2.png",
      "38": "common/icons/38_2.png"
    },
    "default_popup": "common/html/popup.html"
  },
  "permissions": [
    "alarms",
    "notifications",
    "offscreen",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.twitch.tv/*",
    "*://ndragomirov.github.io/*",
    "http://static-cdn.jtvnw.net/*",
    "https://api.twitch.tv/*",
    "https://avatars.githubusercontent.com/*",
    "https://id.twitch.tv/*",
    "https://static-cdn.jtvnw.net/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
